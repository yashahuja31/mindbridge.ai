# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Adzuna official job API (free tier) ---
# Register at https://developer.adzuna.com/ to get an app id + key.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb          # gb, us, in, etc.

# --- Embedding model ---
# sentence-transformers model name. Falls back to TF-IDF if it can't be loaded.
MINDBRIDGE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Scraper adapter (OFF by default) ---
# Scraping LinkedIn/Naukri/Glassdoor violates their Terms of Service and carries
# legal risk. This flag only exists so the pluggable architecture is complete.
# Leave as 0 unless you have explicit authorization for a given source.
MINDBRIDGE_ENABLE_SCRAPER=0

# --- M2 web backend (FastAPI) ---
# Secret used to sign JWT access tokens. The default in code is an obvious
# placeholder; ALWAYS override this with a long random value in production.
MINDBRIDGE_SECRET_KEY=your-secret-key-here

# Cap how many jobs/candidates a source returns. Unset = no cap (loads the full
# 10k demo corpus if present, which slows server startup). Set e.g. 200 for a
# fast-starting dev server or CI.
MINDBRIDGE_CORPUS_LIMIT=200

# --- M4 persistent vector store ---
# Cache stage-1 corpus embeddings under data/processed/vectors/ so a warm start
# skips re-encoding the corpus. Keys include a corpus fingerprint, so stale
# vectors are never served. Set 0 to disable (zero disk writes).
MINDBRIDGE_VECTOR_STORE=1

# --- OAuth sign-in (optional; password auth always works) ---
# A provider's button appears in the UI only when BOTH its id and secret are set.
# Setup guides: docs/AUTH.md. Register the callback URL with the provider as
#   <API_BASE_URL>/auth/oauth/google/callback   (and .../github/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Where the SPA runs (OAuth callbacks land the browser back here) and the public
# base URL of this API (used to build the redirect URIs registered above).
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://127.0.0.1:8000

